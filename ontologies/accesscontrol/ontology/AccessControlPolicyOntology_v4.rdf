    <!-- http://victoriachama.org/net/AccessControlPolicyOntology#AuditPurposeTemporary -->

    <owl:Class rdf:about="http://victoriachama.org/net/AccessControlPolicyOntology#AuditPurposeTemporary">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#Context"/>
