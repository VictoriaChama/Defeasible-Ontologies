    <!-- http://victoriachama.org/net/AccessControlPolicyOntology#Workstation -->

    <owl:Class rdf:about="http://victoriachama.org/net/AccessControlPolicyOntology#Workstation">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#Device"/>
        <rdfs:comment>A desktop computer or terminal used for work.</rdfs:comment>
        <rdfs:label xml:lang="en">Workstation</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#Workstation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#Device"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/AccessControlPolicyOntology#WriteAccess -->

    <owl:Class rdf:about="http://victoriachama.org/net/AccessControlPolicyOntology#WriteAccess">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#Action"/>
        <rdfs:comment>The specific action of creating, modifying, or deleting the contents of a resource.</rdfs:comment>
        <rdfs:label xml:lang="en">WriteAccess</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#WriteAccess"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#Action"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


