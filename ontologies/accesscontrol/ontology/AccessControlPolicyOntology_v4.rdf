        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#User"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#Resource"/>
        <rdfs:comment>A general property indicating that a user accesses a resource.</rdfs:comment>
        <rdfs:label xml:lang="en">accesses</rdfs:label>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#accesses"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#User"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#accesses"/>
