    <!-- http://victoriachama.org/net/AccessControlPolicyOntology#AuthorizedGridOperator -->

    <owl:Class rdf:about="http://victoriachama.org/net/AccessControlPolicyOntology#AuthorizedGridOperator">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#Role"/>
        <rdfs:subClassOf rdf:nodeID="genid294"/>
        <rdfs:comment>A user certified and authorized to issue commands to a power grid control system.</rdfs:comment>
        <rdfs:label xml:lang="en">AuthorizedGridOperator</rdfs:label>
    </owl:Class>
