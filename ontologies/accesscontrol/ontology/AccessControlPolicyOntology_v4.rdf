        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#Resource"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


