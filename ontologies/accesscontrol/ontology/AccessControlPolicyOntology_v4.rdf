    <owl:Class rdf:about="http://victoriachama.org/net/AccessControlPolicyOntology#AuthorizeCovertOperation">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#Action"/>
        <rdfs:comment>The high-level action of authorizing a covert operation, typically by a senior authority.</rdfs:comment>
