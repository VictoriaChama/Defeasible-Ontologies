    <!-- http://victoriachama.org/net/AccessControlPolicyOntology#Admin -->

    <owl:Class rdf:about="http://victoriachama.org/net/AccessControlPolicyOntology#Admin">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#Employee"/>
        <rdfs:subClassOf rdf:nodeID="genid281"/>
        <rdfs:comment>An employee with administrative privileges to manage systems, users, or configurations.</rdfs:comment>
        <rdfs:label xml:lang="en">Admin</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid281">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#canAccess"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/AccessControlPolicyOntology#SystemConfiguration"/>
