    <rdfs:label xml:lang="en">micromanagedResearcher1</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://victoriachama.org/net/EducationLearningOntology/micromanagingSupervisor1">
    <rdf:type rdf:resource="http://victoriachama.org/net/EducationLearningOntology#MicromanagingSupervisor"/>
    <rdfs:comment xml:lang="en">A supervisor who excessively controls research decisions and limits independent learning.</rdfs:comment>
    <rdfs:label xml:lang="en">micromanagingSupervisor1</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://victoriachama.org/net/EducationLearningOntology/lowInteractionOnlineCourse1">
