    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Supervisor -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Supervisor">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Person"/>
        <rdfs:comment>An individual, typically an instructor, who oversees a student&apos;s research, project, or internship.</rdfs:comment>
        <rdfs:label xml:lang="en">Supervisor</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Supervisor"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Person"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Tutee -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Tutee">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Person"/>
        <rdfs:comment>A student who receives specialized instruction and academic support from a tutor.</rdfs:comment>
        <rdfs:label xml:lang="en">Tutee</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Tutee"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Person"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Tutor -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Tutor">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Person"/>
        <rdfs:comment>An individual who provides private or specialized academic instruction to a single student or a small group.</rdfs:comment>
        <rdfs:label xml:lang="en">Tutor</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Tutor"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Person"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#UnderminesIntrinsicMotivation -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#UnderminesIntrinsicMotivation">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment xml:lang="en">Refers to instructional methods or supervision styles that reduce a learner’s internal drive to learn, often through excessive control, external pressure, or irrelevant incentives.</rdfs:comment>
        <rdfs:label xml:lang="en">UnderminesIntrinsicMotivation</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#UnderminesIntrinsicMotivation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Understanding -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Understanding">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
        <rdfs:comment>The ability to comprehend, interpret, and make meaningful connections with learned material.</rdfs:comment>
        <rdfs:label xml:lang="en">Understanding</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Understanding"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#UnpreparedStudents -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#UnpreparedStudents">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:comment xml:lang="en">Learners entering a course or program without the foundational skills or prerequisites necessary for success in the learning environment.</rdfs:comment>
        <rdfs:label xml:lang="en">UnpreparedStudents</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#UnpreparedStudents"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#UnrecognizedIssuer -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#UnrecognizedIssuer">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <rdfs:comment xml:lang="en">Refers to a credentialing or certifying institution that lacks formal accreditation or recognition, affecting the legitimacy of issued qualifications.</rdfs:comment>
        <rdfs:label xml:lang="en">UnrecognizedIssuer</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#UnrecognizedIssuer"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#UnscaffoldedProject -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#UnscaffoldedProject">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <rdfs:comment>A project that requires students to complete a complex task with minimal guidance or explicit structure.</rdfs:comment>
        <rdfs:label xml:lang="en">UnscaffoldedProject</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#UnscaffoldedProject"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#VisualLearner -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#VisualLearner">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:comment>A student who best processes and retains information when it is presented in a graphic or visual format.</rdfs:comment>
        <rdfs:label xml:lang="en">VisualLearner</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#VisualLearner"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#VisualLearnerWithAphantasia -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#VisualLearnerWithAphantasia">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#VisualLearner"/>
        <rdfs:comment>A visual learner who cannot voluntarily create mental images, relying entirely on external visual aids.</rdfs:comment>
        <rdfs:label xml:lang="en">VisualLearnerWithAphantasia</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#VisualLearnerWithAphantasia"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#VisualLearner"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#WorkedExample -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#WorkedExample">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
