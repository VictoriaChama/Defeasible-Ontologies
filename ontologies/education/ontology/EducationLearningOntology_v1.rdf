    <!-- http://victoriachama.org/net/EducationLearningOntology#PublishPressure -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#PublishPressure">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment xml:lang="en">Represents the psychological and professional strain experienced by researchers or postgraduate students due to expectations to publish frequently.</rdfs:comment>
        <rdfs:label xml:lang="en">PublishPressure</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#PublishPressure"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
