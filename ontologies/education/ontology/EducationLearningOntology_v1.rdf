<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/vicki/ontologies/2025/9/untitled-ontology-5/"
     xml:base="http://www.semanticweb.org/vicki/ontologies/2025/9/untitled-ontology-5/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:www="http://www.cair.za.net/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:cair="http://cair.za.net/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:defeasible="http://cair.za.net/defeasible#">
    <owl:Ontology rdf:about="http://victoriachama.org/net/EducationLearningOntology">
        <owl:versionIRI rdf:resource="http://victoriachama.org/net/EducationLearningOntology/1.0.0"/>
        <cair:consistent rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</cair:consistent>
        <terms:license rdf:resource="https://creativecommons.org/publicdomain/zero/1.0"/>
        <rdfs:comment>This ontology models the education and learning path domain with a focus on defeasible knowledge—rules that hold typically but can be overridden by exceptions. It captures common learning patterns, prerequisites, pedagogical methods, and cognitive processes using defeasible subclass axioms, along with explicit defeaters for exceptional cases. The ontology is designed to support reasoning and evaluation with the Defeasible-Inference Platform (DIP) plugin in Protégé, enabling queries over typical rules, exceptions, and contradictions within realistic educational contexts. Typicality axioms are annotated as defeasible for DIP compatibility, while exception cases are modeled through defeater subclasses and conditions</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://cair.za.net/consistent -->

    <owl:AnnotationProperty rdf:about="http://cair.za.net/consistent"/>
    


    <!-- http://cair.za.net/defeasible#defeasible -->

    <owl:AnnotationProperty rdf:about="http://cair.za.net/defeasible#defeasible"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://www.cair.za.net/eTransform -->

    <owl:AnnotationProperty rdf:about="http://www.cair.za.net/eTransform"/>
    


    <!-- http://www.cair.za.net/rank -->

    <owl:AnnotationProperty rdf:about="http://www.cair.za.net/rank"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://victoriachama.org/net/EducationLearningOntology#appliedToTask -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#appliedToTask">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Assessment"/>
        <rdfs:comment xml:lang="en">Connects a resource to a specific task or assignment where it is used (e.g., rubric appliedToTask final essay). Useful for modeling the relationship between instructional tools and outputs.</rdfs:comment>
        <rdfs:label xml:lang="en">applied To Task</rdfs:label>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#appliedToTask"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#appliedToTask"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Assessment"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#benefitsFrom -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#benefitsFrom">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:range rdf:nodeID="genid4"/>
        <rdfs:comment xml:lang="en">Captures that a student gains improved learning, retention, or motivation from a particular method, resource, or intervention (e.g., flashcards, simulations, tutoring). Helps model typical vs. exceptional learning strategies.</rdfs:comment>
        <rdfs:label xml:lang="en">benefits From</rdfs:label>
    </owl:ObjectProperty>
    <owl:Class rdf:nodeID="genid4">
        <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
            <rdf:Description rdf:about="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        </owl:intersectionOf>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#benefitsFrom"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#benefitsFrom"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:nodeID="genid4"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#collaboratesWith -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#collaboratesWith">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:comment xml:lang="en">Expresses peer-to-peer collaboration in study groups, projects, or discussions. This relation is typically symmetric and models social/constructivist aspects of learning.</rdfs:comment>
        <rdfs:label xml:lang="en">collaborates With</rdfs:label>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#collaboratesWith"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#collaboratesWith"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#givesFeedbackTo -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#givesFeedbackTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#receivedFeedback"/>
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Instructor"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:comment xml:lang="en">Represents the act of an instructor providing evaluative or formative feedback to a student. Crucial for modeling feedback loops in learning effectiveness.</rdfs:comment>
        <rdfs:label xml:lang="en">gives Feedback To</rdfs:label>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#givesFeedbackTo"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Instructor"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#givesFeedbackTo"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#hasCondition -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#hasCondition">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:nodeID="genid12"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment xml:lang="en">Links a course or student to contextual factors influencing performance or delivery (e.g., funding availability, illness, limited resources, fieldwork). Enables modeling of defeasible exceptions.</rdfs:comment>
        <rdfs:label xml:lang="en">has Condition</rdfs:label>
    </owl:ObjectProperty>
    <owl:Class rdf:nodeID="genid12">
        <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://victoriachama.org/net/EducationLearningOntology#Course"/>
            <rdf:Description rdf:about="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        </owl:intersectionOf>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasCondition"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:nodeID="genid12"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasCondition"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#hasDelayBecauseOf -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#hasDelayBecauseOf">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Course"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment xml:lang="en">Captures conditions (e.g., fieldwork, lack of funding, administrative hold) that delay program or course completion. Provides a defeasible explanation for deviations in standard timelines.</rdfs:comment>
        <rdfs:label xml:lang="en">has Delay Because Of</rdfs:label>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasDelayBecauseOf"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Course"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasDelayBecauseOf"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#hasDuration -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#hasDuration">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Course"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Course"/>
        <rdfs:comment xml:lang="en">Represents the temporal length of a course, expressed either as a duration (e.g., 16 weeks) or numeric value. Supports planning, workload estimation, and comparison of course intensity.</rdfs:comment>
        <rdfs:label xml:lang="en">has Duration</rdfs:label>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasDuration"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Course"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasDuration"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Course"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#hasEffect -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#hasEffect">
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GamifiedLearning"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/EducationLearningOntology#UnderminesIntrinsicMotivation"/>
        <rdfs:comment xml:lang="en">Represents the measurable or observable impact resulting from a learning approach, instructional design, or intervention.</rdfs:comment>
        <rdfs:label xml:lang="en">has Effect</rdfs:label>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasEffect"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GamifiedLearning"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasEffect"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#UnderminesIntrinsicMotivation"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#hasFeature -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#hasFeature">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Course"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <rdfs:comment xml:lang="en">Captures the instructional or design features of a course or material (e.g., scaffolded exercises, automated feedback, gamification). Supports evaluation of effectiveness and accessibility.</rdfs:comment>
        <rdfs:label xml:lang="en">has Feature</rdfs:label>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasFeature"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Course"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasFeature"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#hasFunding -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#hasFunding">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GrantFunding"/>
        <rdfs:comment xml:lang="en">Links a student or academic program to financial support (scholarships, grants). Funding impacts progression, retention, and may introduce defeasible delays/exceptions.</rdfs:comment>
        <rdfs:label xml:lang="en">has Funding</rdfs:label>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasFunding"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasFunding"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GrantFunding"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#hasGraspOf -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#hasGraspOf">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:range rdf:nodeID="genid28"/>
        <rdfs:comment xml:lang="en">Represents the conceptual or practical mastery a student demonstrates with respect to a specific learning outcome or domain concept.</rdfs:comment>
        <rdfs:label xml:lang="en">has Grasp Of</rdfs:label>
    </owl:ObjectProperty>
    <owl:Class rdf:nodeID="genid28">
        <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://victoriachama.org/net/EducationLearningOntology#Concept"/>
            <rdf:Description rdf:about="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
        </owl:intersectionOf>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasGraspOf"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasGraspOf"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:nodeID="genid28"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#hasHigherAverageOutcome -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#hasHigherAverageOutcome">
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#HighSESStudent"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
        <rdfs:comment xml:lang="en">Denotes that one educational method or program yields, on average, better measurable results (e.g., test scores, retention) than another.</rdfs:comment>
        <rdfs:label xml:lang="en">has Higher Average Outcome</rdfs:label>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasHigherAverageOutcome"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#HighSESStudent"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasHigherAverageOutcome"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#hasHigherProgressLikelihood -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/EducationLearningOntology#hasHigherProgressLikelihood">
        <rdfs:domain rdf:resource="http://victoriachama.org/net/EducationLearningOntology#PublishingPhDStudent"/>
