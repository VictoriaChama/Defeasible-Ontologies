    <!-- http://victoriachama.org/net/EducationLearningOntology#HighTestAnxiety -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#HighTestAnxiety">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment>A psychological state of extreme stress and discomfort before and during exams, which can impair performance.</rdfs:comment>
        <rdfs:label xml:lang="en">HighTestAnxiety</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#HighTestAnxiety"/>
