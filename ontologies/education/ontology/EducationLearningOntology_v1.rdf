        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#ResearchSkill -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#ResearchSkill">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <rdfs:comment xml:lang="en">The ability to design, conduct, analyze, and communicate research effectively using appropriate methodologies and ethical standards.</rdfs:comment>
        <rdfs:label>ResearchSkill</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#ResearchSkill"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Resource -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Resource">
        <rdfs:comment>Any asset, tool, or means of support that can be used to facilitate the learning process.</rdfs:comment>
        <rdfs:label xml:lang="en">Resource</rdfs:label>
    </owl:Class>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Retention -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Retention">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
        <rdfs:comment>The ability of a learner to recall or retain information over a period of time.</rdfs:comment>
        <rdfs:label xml:lang="en">Retention</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Retention"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#RoteMemorizer -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#RoteMemorizer">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:comment>A student who primarily relies on memorizing information through repetition, often without deeper conceptual understanding.</rdfs:comment>
        <rdfs:label xml:lang="en">RoteMemorizer</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#RoteMemorizer"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#ScaffoldedProject -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#ScaffoldedProject">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <rdfs:comment>A project with structured support, guidance, and intermediate steps to help students manage complexity.</rdfs:comment>
        <rdfs:label xml:lang="en">ScaffoldedProject</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#ScaffoldedProject"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#SevereSocialAnxietyStudent -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#SevereSocialAnxietyStudent">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:comment>A student whose learning is significantly hindered by intense fear in social situations, such as group work.</rdfs:comment>
        <rdfs:label xml:lang="en">SevereSocialAnxietyStudent</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#SevereSocialAnxietyStudent"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#ShallowQuestions -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#ShallowQuestions">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <rdfs:comment xml:lang="en">Questions that assess surface-level understanding or recall rather than deeper conceptual comprehension or application.</rdfs:comment>
        <rdfs:label xml:lang="en">ShallowQuestions</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#ShallowQuestions"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#SmallClass -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#SmallClass">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <rdfs:subClassOf rdf:nodeID="genid240"/>
        <rdfs:comment>A pedagogical context with a low student-to-instructor ratio, enabling more personalized instruction.</rdfs:comment>
        <rdfs:label xml:lang="en">SmallClass</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid240">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/EducationLearningOntology#improvesOutcome"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#SmallClass"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#SmallClass"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid240"/>
        <defeasible:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</defeasible:defeasible>
        <www:eTransform rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:eTransform>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#SpacedRepetition -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#SpacedRepetition">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <rdfs:subClassOf rdf:nodeID="genid243"/>
        <rdfs:comment>A learning technique involving reviewing information at increasing intervals to improve long-term retention.</rdfs:comment>
        <rdfs:label xml:lang="en">SpacedRepetition</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid243">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/EducationLearningOntology#retainsLongTerm"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Knowledge"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#SpacedRepetition"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#SpacedRepetition"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid243"/>
        <defeasible:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</defeasible:defeasible>
        <www:eTransform rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:eTransform>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Student -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Student">
