    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#HighSESStudent"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid169"/>
        <defeasible:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</defeasible:defeasible>
