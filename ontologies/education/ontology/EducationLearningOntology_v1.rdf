        <rdfs:subClassOf rdf:nodeID="genid246"/>
        <rdfs:comment>An individual enrolled in a course or program of study for the purpose of learning.</rdfs:comment>
        <rdfs:label xml:lang="en">Student</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid246">
