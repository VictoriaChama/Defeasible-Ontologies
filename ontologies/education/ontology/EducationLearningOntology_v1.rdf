        <rdfs:subClassOf rdf:nodeID="genid231"/>
        <rdfs:comment xml:lang="en">A doctoral candidate actively involved in disseminating research findings through academic publications, reflecting advanced research competence.</rdfs:comment>
        <rdfs:label xml:lang="en">PublishingPhDStudent</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid231">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasHigherProgressLikelihood"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#PublishingPhDStudent"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#PhDStudent"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#PublishingPhDStudent"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid231"/>
        <defeasible:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</defeasible:defeasible>
