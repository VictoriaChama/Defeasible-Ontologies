        <rdfs:subClassOf rdf:nodeID="genid227"/>
        <rdfs:comment>An instructional approach where students learn by engaging in and solving complex, real-world projects.</rdfs:comment>
        <rdfs:label xml:lang="en">ProjectBasedLearning</rdfs:label>
    </owl:Class>
