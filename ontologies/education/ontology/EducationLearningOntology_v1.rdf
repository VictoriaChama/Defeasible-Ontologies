        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#IntrinsicReward -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#IntrinsicReward">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <rdfs:comment>An internal, psychological reward derived from the learning activity itself, such as a sense of accomplishment or enjoyment.</rdfs:comment>
        <rdfs:label xml:lang="en">IntrinsicReward</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#IntrinsicReward"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Knowledge -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Knowledge">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <rdfs:comment xml:lang="en">Represents acquired information, understanding, or skills derived from experience, education, or training within a learning domain.</rdfs:comment>
        <rdfs:label>Knowledge</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Knowledge"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#LabWork -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#LabWork">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <rdfs:comment>A hands-on learning activity in a controlled environment to apply theoretical concepts and develop skills.</rdfs:comment>
        <rdfs:label xml:lang="en">LabWork</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LabWork"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#LackOfFunding -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#LackOfFunding">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment>A constraint where insufficient financial resources limit educational activities, research, or access to materials.</rdfs:comment>
        <rdfs:label xml:lang="en">LackOfFunding</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LackOfFunding"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#LearningActivity -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#LearningActivity">
        <rdfs:comment>Any specific task, process, or interaction in which a student engages for the purpose of learning.</rdfs:comment>
        <rdfs:label xml:lang="en">LearningActivity</rdfs:label>
    </owl:Class>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Lecture -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Lecture">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <rdfs:comment>An oral presentation by an instructor intended to convey information to an audience of learners.</rdfs:comment>
        <rdfs:label xml:lang="en">Lecture</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Lecture"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#MaterialAtHighLevel -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#MaterialAtHighLevel">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <rdfs:comment xml:lang="en">Represents educational materials designed at a conceptual or abstract level that may exceed the learner’s current stage of understanding. Useful for modeling cognitive mismatch or advanced instructional design.</rdfs:comment>
        <rdfs:label xml:lang="en">MaterialAtHighLevel</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#MaterialAtHighLevel"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#MenialTasks -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#MenialTasks">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <rdfs:comment xml:lang="en">Represents repetitive or low-complexity activities assigned to learners or interns that do not contribute meaningfully to skill development or learning objectives.</rdfs:comment>
        <rdfs:label xml:lang="en">MenialTasks</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#MenialTasks"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#MicromanagingSupervisor -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#MicromanagingSupervisor">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Supervisor"/>
        <rdfs:comment xml:lang="en">Describes a supervisor or mentor who exerts excessive control over a learner’s tasks, often limiting autonomy and self-directed development. Can negatively impact motivation and creativity.</rdfs:comment>
        <rdfs:label xml:lang="en">MicromanagingSupervisor</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#MicromanagingSupervisor"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Supervisor"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Misconception -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Misconception">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment>A learner&apos;s belief or understanding that is conceptually incorrect or conflicts with established knowledge.</rdfs:comment>
        <rdfs:label xml:lang="en">Misconception</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Misconception"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#MisguidedTutor -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#MisguidedTutor">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Tutor"/>
        <rdfs:comment>A tutor who provides incorrect information, poor learning strategies, or counterproductive guidance.</rdfs:comment>
        <rdfs:label xml:lang="en">MisguidedTutor</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#MisguidedTutor"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Tutor"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Motivation -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Motivation">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
        <rdfs:comment>The internal state that arouses, directs, and sustains a student&apos;s learning-oriented behavior.</rdfs:comment>
        <rdfs:label xml:lang="en">Motivation</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Motivation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#NoviceLearner -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#NoviceLearner">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:comment>A student with little to no prior knowledge or experience in a specific domain, requiring foundational instruction.</rdfs:comment>
        <rdfs:label xml:lang="en">NoviceLearner</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#NoviceLearner"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#NoviceResearcher -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#NoviceResearcher">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:subClassOf rdf:nodeID="genid196"/>
        <rdfs:comment xml:lang="en">Refers to an early-stage researcher or postgraduate student still developing research methodology skills, critical thinking, and academic writing proficiency.</rdfs:comment>
        <rdfs:label xml:lang="en">NoviceResearcher</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid196">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/EducationLearningOntology#improvesDevelopment"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/EducationLearningOntology#ResearchSkill"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#NoviceResearcher"/>
