    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#ProjectBasedCourse">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Course"/>
        <rdfs:comment>A course where the primary learning activity involves students working on a complex, long-term project.</rdfs:comment>
        <rdfs:label xml:lang="en">ProjectBasedCourse</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#ProjectBasedCourse"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
