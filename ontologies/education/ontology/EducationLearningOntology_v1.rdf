    <!-- http://victoriachama.org/net/EducationLearningOntology#Internship -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Internship">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <rdfs:subClassOf rdf:nodeID="genid181"/>
        <rdfs:comment>A temporary, supervised work experience in a professional field related to a student&apos;s field of study.</rdfs:comment>
        <rdfs:label xml:lang="en">Internship</rdfs:label>
    </owl:Class>
