        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#SummativeAssessment -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#SummativeAssessment">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Assessment"/>
        <rdfs:comment>Assessment of learning, used to evaluate student mastery at the end of an instructional unit (e.g., final exams).</rdfs:comment>
        <rdfs:label xml:lang="en">SummativeAssessment</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#SummativeAssessment"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
