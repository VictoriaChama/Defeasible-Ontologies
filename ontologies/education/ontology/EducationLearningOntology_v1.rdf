    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Employability -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Employability">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
        <rdfs:comment>The set of skills, knowledge, and attributes that make a student likely to gain and maintain employment.</rdfs:comment>
        <rdfs:label xml:lang="en">Employability</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Employability"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Exam -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Exam">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Assessment"/>
        <rdfs:comment xml:lang="en">A formal assessment designed to evaluate a learner’s knowledge, skills, or competencies, typically summative in nature.</rdfs:comment>
        <rdfs:label xml:lang="en">Exam</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Exam"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Assessment"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#ExperiencedInstructor -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#ExperiencedInstructor">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Instructor"/>
        <rdfs:comment>An instructor with significant teaching experience and well-developed pedagogical skills.</rdfs:comment>
        <rdfs:label xml:lang="en">ExperiencedInstructor</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#ExperiencedInstructor"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Instructor"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#ExtremeNonAcademicStress -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#ExtremeNonAcademicStress">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment xml:lang="en">Refers to severe stress factors unrelated to academic workload that significantly hinder a learner’s ability to focus, perform, or persist in their studies.</rdfs:comment>
        <rdfs:label xml:lang="en">ExtremeNonAcademicStress</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#ExtremeNonAcademicStress"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#ExtrinsicReward -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#ExtrinsicReward">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <rdfs:comment>A tangible reward given for an achievement, such as grades, points, or praise, to motivate behavior.</rdfs:comment>
        <rdfs:label xml:lang="en">ExtrinsicReward</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#ExtrinsicReward"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Fatigue -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Fatigue">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment>A state of mental or physical exhaustion that impairs a learner&apos;s cognitive functions and ability to focus.</rdfs:comment>
        <rdfs:label xml:lang="en">Fatigue</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Fatigue"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Feature -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Feature">
        <rdfs:comment>A distinct characteristic or element of a learning environment, tool, or activity.</rdfs:comment>
        <rdfs:label xml:lang="en">Feature</rdfs:label>
    </owl:Class>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#FieldworkDelay -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#FieldworkDelay">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment>An unforeseen delay in project work or data collection conducted outside of the traditional classroom setting.</rdfs:comment>
        <rdfs:label xml:lang="en">FieldworkDelay</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#FieldworkDelay"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#FlippedClassroom -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#FlippedClassroom">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <rdfs:comment>A model where students review lecture materials at home and class time is used for interactive activities.</rdfs:comment>
        <rdfs:label xml:lang="en">FlippedClassroom</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#FlippedClassroom"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#FormativeAssessment -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#FormativeAssessment">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Assessment"/>
        <rdfs:comment>Assessment for learning, used to monitor student progress and provide ongoing feedback (e.g., quizzes, drafts).</rdfs:comment>
        <rdfs:label xml:lang="en">FormativeAssessment</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#FormativeAssessment"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Assessment"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#FormativeAssessmentCycle -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#FormativeAssessmentCycle">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <rdfs:subClassOf rdf:nodeID="genid151"/>
        <rdfs:comment xml:lang="en">A continuous process of assessment, feedback, and reflection aimed at improving learning during instruction rather than evaluating it at the end.</rdfs:comment>
        <rdfs:label xml:lang="en">FormativeAssessmentCycle</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid151">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/EducationLearningOntology#improvesDevelopment"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#FormativeAssessmentCycle"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#FormativeAssessmentCycle"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid151"/>
        <defeasible:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</defeasible:defeasible>
        <www:eTransform rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:eTransform>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#GamifiedLearning -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#GamifiedLearning">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <rdfs:subClassOf rdf:nodeID="genid154"/>
        <rdfs:comment xml:lang="en">An instructional approach that integrates game elements (points, levels, challenges) into educational contexts to increase motivation and engagement.</rdfs:comment>
        <rdfs:label xml:lang="en">GamifiedLearning</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid154">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/EducationLearningOntology#increasesEngagementOf"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GamifiedLearning"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GamifiedLearning"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid154"/>
        <defeasible:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</defeasible:defeasible>
        <www:eTransform rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:eTransform>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#GiftedStudent -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#GiftedStudent">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:comment>A student demonstrating exceptionally high ability in one or more areas (e.g., intellectual, creative, artistic).</rdfs:comment>
        <rdfs:label xml:lang="en">GiftedStudent</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GiftedStudent"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#GoodInstructorFeedback -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#GoodInstructorFeedback">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <rdfs:subClassOf rdf:nodeID="genid158"/>
        <rdfs:comment xml:lang="en">Feedback from instructors that is timely, specific, constructive, and aimed at enhancing student learning and self-efficacy.</rdfs:comment>
        <rdfs:label xml:lang="en">GoodInstructorFeedback</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid158">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/EducationLearningOntology#increasesMotivationOf"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GoodInstructorFeedback"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Pedagogy"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GoodInstructorFeedback"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid158"/>
        <defeasible:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</defeasible:defeasible>
        <www:eTransform rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:eTransform>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#GrantFunding -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#GrantFunding">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <rdfs:comment>Financial resources provided by an organization to support a research project, program, or student.</rdfs:comment>
        <rdfs:label xml:lang="en">GrantFunding</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GrantFunding"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Resource"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#GroupWork -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#GroupWork">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <rdfs:subClassOf rdf:nodeID="genid162"/>
        <rdfs:comment>A collaborative learning activity where students work together to complete a shared task or goal.</rdfs:comment>
        <rdfs:label xml:lang="en">GroupWork</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid162">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/EducationLearningOntology#improvesRetention"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GroupWork"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#GroupWork"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid162"/>
        <defeasible:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</defeasible:defeasible>
        <www:eTransform rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:eTransform>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#HighCognitiveLoad -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#HighCognitiveLoad">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment>A state where the mental effort required to process information exceeds a learner&apos;s cognitive capacity, impeding learning.</rdfs:comment>
        <rdfs:label xml:lang="en">HighCognitiveLoad</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#HighCognitiveLoad"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#HighFrequency -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#HighFrequency">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <rdfs:comment xml:lang="en">Describes events, interactions, or learning activities that occur very often within a given period. Useful for modeling cognitive load or engagement patterns.</rdfs:comment>
        <rdfs:label xml:lang="en">HighFrequency</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#HighFrequency"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#HighPriorKnowledge -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#HighPriorKnowledge">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <rdfs:comment>A state where a learner begins instruction already possessing substantial relevant knowledge.</rdfs:comment>
        <rdfs:label xml:lang="en">HighPriorKnowledge</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#HighPriorKnowledge"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Condition"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#HighPriorKnowledgeLearner -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#HighPriorKnowledgeLearner">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:comment>A learner who enters an educational setting with substantial pre-existing knowledge in the subject area.</rdfs:comment>
        <rdfs:label xml:lang="en">HighPriorKnowledgeLearner</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#HighPriorKnowledgeLearner"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#HighSESStudent -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#HighSESStudent">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
        <rdfs:subClassOf rdf:nodeID="genid169"/>
        <rdfs:comment xml:lang="en">A student from a high socioeconomic status background, often associated with greater access to educational resources and opportunities.</rdfs:comment>
        <rdfs:label xml:lang="en">HighSESStudent</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid169">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/EducationLearningOntology#hasHigherAverageOutcome"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Outcome"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#HighSESStudent"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
