    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#ImmediateFeedback -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#ImmediateFeedback">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <rdfs:comment>Information on performance that is provided to a learner directly after an action is completed.</rdfs:comment>
        <rdfs:label xml:lang="en">ImmediateFeedback</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#ImmediateFeedback"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#ImmediateSummativeTest -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#ImmediateSummativeTest">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <rdfs:subClassOf rdf:nodeID="genid174"/>
        <rdfs:comment xml:lang="en">A post-learning evaluation conducted directly after instruction to measure short-term retention or immediate learning outcomes.</rdfs:comment>
        <rdfs:label xml:lang="en">ImmediateSummativeTest</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid174">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/EducationLearningOntology#revealsMastery"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Student"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#ImmediateSummativeTest"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#LearningActivity"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#ImmediateSummativeTest"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid174"/>
        <defeasible:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</defeasible:defeasible>
        <www:eTransform rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:eTransform>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#InPersonCourse -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#InPersonCourse">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Course"/>
        <rdfs:comment>A course where instruction is delivered in a physical location with the instructor and students present.</rdfs:comment>
        <rdfs:label xml:lang="en">InPersonCourse</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#InPersonCourse"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Course"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#InconsistentAmbiguous -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#InconsistentAmbiguous">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <rdfs:comment xml:lang="en">Describes situations, materials, or feedback that lack clarity or contain contradictions, potentially leading to learner confusion or misinterpretation.</rdfs:comment>
        <rdfs:label xml:lang="en">InconsistentAmbiguous</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#InconsistentAmbiguous"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Feature"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#InexperiencedInstructor -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#InexperiencedInstructor">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Instructor"/>
        <rdfs:comment>An instructor who is new to teaching and is still developing their instructional methods.</rdfs:comment>
        <rdfs:label xml:lang="en">InexperiencedInstructor</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/EducationLearningOntology#InexperiencedInstructor"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Instructor"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/EducationLearningOntology#Instructor -->

    <owl:Class rdf:about="http://victoriachama.org/net/EducationLearningOntology#Instructor">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/EducationLearningOntology#Person"/>
        <rdfs:comment>An individual responsible for teaching or providing instruction in a formal educational setting.</rdfs:comment>
        <rdfs:label xml:lang="en">Instructor</rdfs:label>
    </owl:Class>
