    <rdf:type rdf:resource="http://victoriachama.org/net/EducationLearningOntology#NoviceResearcher"/>
    <hasSupervisor rdf:resource="http://victoriachama.org/net/EducationLearningOntology/micromanagingSupervisor1"/>
