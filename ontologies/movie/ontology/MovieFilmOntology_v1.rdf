    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#AntiWar -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#AntiWar">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#War"/>
