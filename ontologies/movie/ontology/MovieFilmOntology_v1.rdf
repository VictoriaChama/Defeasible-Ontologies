        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#RomanticComedy -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#RomanticComedy">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Comedy"/>
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#HybridGenre"/>
        <rdfs:subClassOf rdf:nodeID="genid472"/>
        <rdfs:comment xml:lang="en">A film that combines the plot of a romance with the lighthearted humor of a comedy.</rdfs:comment>
        <rdfs:label xml:lang="en">RomanticComedy</rdfs:label>
    </owl:Class>
