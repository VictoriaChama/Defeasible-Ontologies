    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#SacrificeEnding -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#SacrificeEnding">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieEndingType"/>
        <rdfs:comment xml:lang="en">A movie ending where a character (often the protagonist) gives up their life or something of great value for a greater good.</rdfs:comment>
        <rdfs:label xml:lang="en">SacrificeEnding</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#SacrificeEnding"/>
