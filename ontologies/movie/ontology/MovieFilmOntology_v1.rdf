        <rdfs:label xml:lang="en">AwardQuality</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#AwardQuality"/>
