    <!-- http://victoriachama.org/net/MovieFilmOntology#CriticallyAcclaimedMajorStudioFailure -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#CriticallyAcclaimedMajorStudioFailure">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MajorStudioBoxOfficeFailure"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf rdf:nodeID="genid210"/>
        <rdfs:comment xml:lang="en">A movie from a major studio that received high praise from critics but failed to find a large audience at the box office.</rdfs:comment>
        <rdfs:label xml:lang="en">CriticallyAcclaimedMajorStudioFailure</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid210">
