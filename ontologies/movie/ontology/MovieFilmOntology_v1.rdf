    <!-- http://victoriachama.org/net/MovieFilmOntology#followsGenreOf -->

    <owl:ObjectProperty rdf:about="http://victoriachama.org/net/MovieFilmOntology#followsGenreOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Movie"/>
        <rdfs:range rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Movie"/>
        <rdfs:comment xml:lang="en">A film&apos;s style refers to the techniques a director uses to create a movie, and it can include themes, sound, dialogue, cinematography and lighting.</rdfs:comment>
        <rdfs:label xml:lang="en">follows Genre Of</rdfs:label>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#followsGenreOf"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#domain"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Movie"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#followsGenreOf"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#range"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Movie"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


