    <!-- http://victoriachama.org/net/MovieFilmOntology#AcademicReview -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#AcademicReview">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Review"/>
        <rdfs:comment xml:lang="en">A film review published in a scholarly journal, often focusing on theoretical, historical, or cultural analysis.</rdfs:comment>
        <rdfs:label xml:lang="en">AcademicReview</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#AcademicReview"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Review"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#AccurateToneGenre -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#AccurateToneGenre">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Tone"/>
        <rdfs:comment xml:lang="en">A film where the marketing (like trailers) accurately represents the final film&apos;s tone and genre.</rdfs:comment>
        <rdfs:label xml:lang="en">AccurateToneAndGenre</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#AccurateToneGenre"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Tone"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Action -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Action">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Genre"/>
        <rdfs:subClassOf rdf:nodeID="genid88"/>
        <rdfs:comment xml:lang="en">A film genre characterized by sequences of violence, extended fighting, physical feats, and chases.</rdfs:comment>
        <rdfs:label xml:lang="en">Action</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid88">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/MovieFilmOntology#hasProtagonist"/>
        <owl:someValuesFrom>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://victoriachama.org/net/MovieFilmOntology#Actor"/>
                    <rdf:Description rdf:about="http://victoriachama.org/net/MovieFilmOntology#Person"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:someValuesFrom>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Action"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Genre"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Action"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid88"/>
        <defeasible:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</defeasible:defeasible>
        <www:eTransform rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:eTransform>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#ActionComedy -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#ActionComedy">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#HybridGenre"/>
        <rdfs:comment xml:lang="en">A film that combines the high-stakes physical feats and violence of the action genre with the humor of the comedy genre.</rdfs:comment>
        <rdfs:label xml:lang="en">ActionComedy</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#ActionComedy"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#HybridGenre"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#ActionThriller -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#ActionThriller">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#HybridGenre"/>
        <rdfs:comment xml:lang="en">A film that blends the intense physical sequences of the action genre with the suspense and tension of the thriller genre.</rdfs:comment>
        <rdfs:label xml:lang="en">ActionThriller</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#ActionThriller"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#HybridGenre"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Actor -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Actor">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Person"/>
        <rdfs:comment xml:lang="en">An individual who portrays a character in a film.</rdfs:comment>
        <rdfs:label xml:lang="en">Actor</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Actor"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Person"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#ActorCastAgainstType -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#ActorCastAgainstType">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Person"/>
        <rdfs:comment xml:lang="en">An actor who is cast in a role that is very different from their usual or expected roles.</rdfs:comment>
        <rdfs:label xml:lang="en">ActorCastAgainstType</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#ActorCastAgainstType"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Person"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Actress -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Actress">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Person"/>
        <rdfs:comment xml:lang="en">A female individual who portrays a character in a film.</rdfs:comment>
        <rdfs:label xml:lang="en">Actress</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Actress"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Person"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
