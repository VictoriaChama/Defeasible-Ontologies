    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Thriller -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Thriller">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Genre"/>
        <rdfs:subClassOf rdf:nodeID="genid523"/>
        <rdfs:comment xml:lang="en">A film genre that uses suspense, tension, and excitement as its main elements, often involving a protagonist in a dangerous situation.</rdfs:comment>
        <rdfs:label xml:lang="en">Thriller</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid523">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/MovieFilmOntology#hasTone"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Violence"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Thriller"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Genre"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Thriller"/>
