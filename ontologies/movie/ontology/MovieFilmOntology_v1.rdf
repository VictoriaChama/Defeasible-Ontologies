    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#TragicRomance -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#TragicRomance">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Romance"/>
        <rdfs:comment xml:lang="en">A romance film where the relationship is doomed to end in separation or death.</rdfs:comment>
        <rdfs:label xml:lang="en">TragicRomance</rdfs:label>
    </owl:Class>
