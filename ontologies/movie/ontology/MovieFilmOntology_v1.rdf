    <!-- http://victoriachama.org/net/MovieFilmOntology#RomanticDrama -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#RomanticDrama">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Drama"/>
        <rdfs:comment xml:lang="en">A drama film that focuses on the challenges, passion, and emotional journey of a romantic relationship.</rdfs:comment>
