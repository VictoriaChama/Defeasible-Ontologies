        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Movie"/>
        <rdfs:comment xml:lang="en">A movie featuring an actor in a role that is very different from their usual or expected character types.</rdfs:comment>
        <rdfs:label xml:lang="en">CastAgainstType</rdfs:label>
    </owl:Class>
    <owl:Axiom>
