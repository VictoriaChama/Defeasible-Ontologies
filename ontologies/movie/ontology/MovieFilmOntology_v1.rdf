    <!-- http://victoriachama.org/net/MovieFilmOntology#TrueCrimeDocumentary -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#TrueCrimeDocumentary">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Documentary"/>
        <rdfs:comment xml:lang="en">A subgenre of documentary that examines a real crime, often detailing the investigation, and the stories of the victims and perpetrators.</rdfs:comment>
        <rdfs:label xml:lang="en">TrueCrimeDocumentary</rdfs:label>
    </owl:Class>
