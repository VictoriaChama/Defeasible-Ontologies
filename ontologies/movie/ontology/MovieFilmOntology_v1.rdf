        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Sequel"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Review -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Review">
        <rdfs:comment xml:lang="en">A written or spoken analysis and evaluation of a film, typically by a critic or audience member.</rdfs:comment>
        <rdfs:label xml:lang="en">Review</rdfs:label>
    </owl:Class>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#RevisionistWestern -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#RevisionistWestern">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Western"/>
        <rdfs:comment xml:lang="en">A western film that subverts or challenges the traditional myths and heroic archetypes of the genre, often with a darker or more realistic tone.</rdfs:comment>
        <rdfs:label xml:lang="en">RevisionistWestern</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#RevisionistWestern"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Western"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#RoleRedefiningCastAgainstTypeActor -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#RoleRedefiningCastAgainstTypeActor">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#ActorCastAgainstType"/>
        <rdfs:comment xml:lang="en">An actor cast against type whose performance was so strong it redefined their public image or career.</rdfs:comment>
        <rdfs:label xml:lang="en">RoleRedefiningCastAgainstTypeActor</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#RoleRedefiningCastAgainstTypeActor"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#ActorCastAgainstType"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Romance -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Romance">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Genre"/>
        <rdfs:comment xml:lang="en">A film genre centered on the development of a romantic relationship between two people.</rdfs:comment>
        <rdfs:label xml:lang="en">Romance</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Romance"/>
