        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Theme -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Theme">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieElements"/>
        <rdfs:comment xml:lang="en">The central subject, message, or underlying idea that a film explores (e.g., love, war, justice, redemption).</rdfs:comment>
        <rdfs:label xml:lang="en">Theme</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Theme"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
