        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieElements"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Slapstick -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Slapstick">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Comedy"/>
        <rdfs:comment xml:lang="en">A comedy subgenre characterized by exaggerated physical activity and broad, farcical humor.</rdfs:comment>
        <rdfs:label xml:lang="en">Slapstick</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Slapstick"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Comedy"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Slasher -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Slasher">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Horror"/>
        <rdfs:comment xml:lang="en">A horror subgenre involving a killer (often masked) who stalks and murders a group of people, usually with bladed tools.</rdfs:comment>
        <rdfs:label xml:lang="en">Slasher</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Slasher"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Horror"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Soundtrack -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Soundtrack">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieElements"/>
        <rdfs:comment xml:lang="en">The recorded music and songs that accompany and are synchronized with the film, often compiled as a commercial album.</rdfs:comment>
        <rdfs:label xml:lang="en">Soundtrack</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Soundtrack"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieElements"/>
