    <!-- http://victoriachama.org/net/MovieFilmOntology#CastInTypicalRole -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#CastInTypicalRole">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Movie"/>
        <rdfs:comment xml:lang="en">A movie featuring an actor in a role that is very similar to the characters they are famous for playing.</rdfs:comment>
        <rdfs:label xml:lang="en">CastInTypicalRole</rdfs:label>
    </owl:Class>
    <owl:Axiom>
