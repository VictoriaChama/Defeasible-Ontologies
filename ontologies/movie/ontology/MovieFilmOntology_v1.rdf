        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieQuality"/>
        <rdfs:comment xml:lang="en">A sequel or remake that is considered by critics or audiences to be at least as good as, or better than, the original film.</rdfs:comment>
