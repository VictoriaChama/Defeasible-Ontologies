    <!-- http://victoriachama.org/net/MovieFilmOntology#Crime -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Crime">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Genre"/>
        <rdfs:comment xml:lang="en">A film genre that focuses on the world of crime, criminals, and their activities, often from the perspective of law enforcement or the criminals themselves.</rdfs:comment>
        <rdfs:label xml:lang="en">Crime</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Crime"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Genre"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#CrimeThriller -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#CrimeThriller">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#HybridGenre"/>
        <rdfs:comment xml:lang="en">A film that combines the criminal world focus of the crime genre with the suspense and high stakes of the thriller genre.</rdfs:comment>
        <rdfs:label xml:lang="en">CrimeThriller</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#CrimeThriller"/>
