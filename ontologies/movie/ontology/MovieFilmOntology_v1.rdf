    <!-- http://victoriachama.org/net/MovieFilmOntology#Tone -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Tone">
        <rdfs:comment xml:lang="en">The prevailing mood or emotional quality of a film — for example, whimsical, melancholic, satirical, or tense.</rdfs:comment>
        <rdfs:label xml:lang="en">Tone</rdfs:label>
    </owl:Class>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#TragicEnding -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#TragicEnding">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Tone"/>
        <rdfs:comment xml:lang="en">A film ending that concludes with a great loss, disaster, or the downfall of the protagonist.</rdfs:comment>
        <rdfs:label xml:lang="en">TragicEnding</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#TragicEnding"/>
