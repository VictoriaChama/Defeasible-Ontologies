        <rdfs:comment xml:lang="en">A general class representing any original intellectual or artistic creation. Films and movies are instances of a Creative Work.</rdfs:comment>
        <rdfs:label xml:lang="en">Creative Work</rdfs:label>
    </owl:Class>
