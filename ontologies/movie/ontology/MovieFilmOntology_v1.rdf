    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#StopMotion -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#StopMotion">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#AnimationTechnique"/>
        <rdfs:comment xml:lang="en">An animation technique where physical objects are moved in small increments between individually photographed frames, creating the illusion of movement.</rdfs:comment>
        <rdfs:label xml:lang="en">StopMotion</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#StopMotion"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#AnimationTechnique"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Studio -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Studio">
        <rdfs:comment xml:lang="en">An organization responsible for producing or financing films — for example, &apos;Warner Bros.&apos;, &apos;A24&apos;, or &apos;BBC Films&apos;.</rdfs:comment>
        <rdfs:label xml:lang="en">Studio</rdfs:label>
    </owl:Class>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#SubjectivePresentation -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#SubjectivePresentation">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#DocumentaryStyle"/>
        <rdfs:comment xml:lang="en">Subjective cinema refers to a film, scene, or shot that emulates a personal POV using cinematography, editing, or other film techniques.</rdfs:comment>
        <rdfs:label xml:lang="en">SubjectivePresentation</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#SubjectivePresentation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#DocumentaryStyle"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#SubjectiveQuality -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#SubjectiveQuality">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieQuality"/>
        <rdfs:comment xml:lang="en">An assessment of a film&apos;s quality based on personal taste and individual opinion rather than objective metrics.</rdfs:comment>
        <rdfs:label xml:lang="en">SubjectiveQuality</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#SubjectiveQuality"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieQuality"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#SupernaturalHorror -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#SupernaturalHorror">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Horror"/>
        <rdfs:comment xml:lang="en">A horror subgenre that involves ghosts, demons, or other supernatural beings or phenomena as the source of fear.</rdfs:comment>
        <rdfs:label xml:lang="en">SupernaturalHorror</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#SupernaturalHorror"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Horror"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#SupernaturalTone -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#SupernaturalTone">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Tone"/>
        <rdfs:comment xml:lang="en">A film tone that suggests the presence of forces or phenomena beyond the laws of nature.</rdfs:comment>
        <rdfs:label xml:lang="en">SupernaturalTone</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#SupernaturalTone"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Tone"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Swashbuckler -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Swashbuckler">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Movie"/>
        <rdfs:comment xml:lang="en">A movie, typically in the action/adventure genre, characterized by heroic protagonists, sword fighting, and daring, acrobatic stunts.</rdfs:comment>
        <rdfs:label xml:lang="en">Swashbuckler</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Swashbuckler"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Movie"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Teen -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Teen">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Audience"/>
        <rdfs:comment xml:lang="en">A movie marketed towards teenagers, often set in a high school and focusing on adolescent issues.</rdfs:comment>
        <rdfs:label xml:lang="en">Teen</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Teen"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
