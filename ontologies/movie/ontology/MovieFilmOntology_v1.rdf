    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#SpaceOpera -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#SpaceOpera">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#ScienceFiction"/>
        <rdfs:comment xml:lang="en">A subgenre of science fiction emphasizing space warfare, melodramatic adventure, interplanetary battles, and chivalric romance.</rdfs:comment>
        <rdfs:label xml:lang="en">SpaceOpera</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#SpaceOpera"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#ScienceFiction"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#SpaghettiWestern -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#SpaghettiWestern">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Western"/>
        <rdfs:comment xml:lang="en">A western subgenre that emerged in the 1960s, primarily produced in Italy, known for its stylized violence, minimalist dialogue, and cynical anti-heroes.</rdfs:comment>
        <rdfs:label xml:lang="en">SpaghettiWestern</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#SpaghettiWestern"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Western"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#SpirituallyAccurateBiopic -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#SpirituallyAccurateBiopic">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#CreativeLibertyBiopic"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf rdf:nodeID="genid506"/>
        <rdfs:comment xml:lang="en">A biographical film that aims to capture the essence, character, and truth of its subject&apos;s life, even if minor factual details are altered for narrative flow.</rdfs:comment>
        <rdfs:label xml:lang="en">SpirituallyAccurateBiopic</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid506">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/MovieFilmOntology#hasAccuracy"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/MovieFilmOntology#HistoricalAccurate"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#SpirituallyAccurateBiopic"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#CreativeLibertyBiopic"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#SpirituallyAccurateBiopic"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
