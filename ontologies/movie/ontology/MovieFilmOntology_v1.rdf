    <!-- http://victoriachama.org/net/MovieFilmOntology#CriticReview -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#CriticReview">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Review"/>
        <rdfs:comment xml:lang="en">A film review written by a professional film critic.</rdfs:comment>
        <rdfs:label xml:lang="en">CriticReview</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#CriticReview"/>
