        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieLocation"/>
        <rdfs:comment xml:lang="en">The physical or fictional location where a film&apos;s story takes place — for example, &apos;New York City&apos;, &apos;a spaceship&apos;, or &apos;rural Zambia&apos;.</rdfs:comment>
        <rdfs:label xml:lang="en">SameLocation</rdfs:label>
    </owl:Class>
