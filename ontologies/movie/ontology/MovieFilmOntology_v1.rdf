    <!-- http://victoriachama.org/net/MovieFilmOntology#StandInLocation -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#StandInLocation">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieLocation"/>
        <rdfs:comment xml:lang="en">A filming location used to represent a different fictional location (e.g., Vancouver standing in for New York).</rdfs:comment>
        <rdfs:label xml:lang="en">StandInLocation</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#StandInLocation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieLocation"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#StaticProtagonist -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#StaticProtagonist">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Protagonist"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf rdf:nodeID="genid511"/>
        <rdfs:comment xml:lang="en">a main character in a movie who does not undergo significant personal change or growth throughout the story</rdfs:comment>
        <rdfs:label xml:lang="en">Static Protagonist</rdfs:label>
    </owl:Class>
    <owl:Class rdf:nodeID="genid511">
        <owl:complementOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://victoriachama.org/net/MovieFilmOntology#undergoes"/>
                <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/MovieFilmOntology#SignificantCharacterDevelopment"/>
            </owl:Restriction>
        </owl:complementOf>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#StaticProtagonist"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Protagonist"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#StaticProtagonist"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <cair:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</cair:defeasible>
