    <!-- http://victoriachama.org/net/MovieFilmOntology#TwistPreservingMisleadingTrailer -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#TwistPreservingMisleadingTrailer">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MisleadingMovieTrailer"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:subClassOf rdf:nodeID="genid530"/>
        <rdfs:comment xml:lang="en">A misleading trailer that is crafted specifically to avoid revealing a major plot twist, often by implying a different story.</rdfs:comment>
        <rdfs:label xml:lang="en">TwistPreservingMisleadingTrailer</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid530">
        <owl:onProperty rdf:resource="http://victoriachama.org/net/MovieFilmOntology#represents"/>
        <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/MovieFilmOntology#AccurateToneGenre"/>
    </owl:Restriction>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#TwistPreservingMisleadingTrailer"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MisleadingMovieTrailer"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#TwistPreservingMisleadingTrailer"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <cair:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</cair:defeasible>
