        <rdfs:label xml:lang="en">AnimationTechnique</rdfs:label>
    </owl:Class>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Anime -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Anime">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#AnimationTechnique"/>
        <rdfs:comment xml:lang="en">A style of animation originating from Japan, characterized by distinct visual aesthetics, stylized characters, and often mature or complex themes.</rdfs:comment>
