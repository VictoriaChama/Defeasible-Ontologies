    <!-- http://victoriachama.org/net/MovieFilmOntology#CliffhangerEnding -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#CliffhangerEnding">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#MovieEndingType"/>
        <rdfs:comment xml:lang="en">A movie ending that leaves the main characters in a precarious or unresolved situation, often to create suspense for a sequel.</rdfs:comment>
        <rdfs:label xml:lang="en">CliffhangerEnding</rdfs:label>
