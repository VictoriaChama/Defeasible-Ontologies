    <!-- http://victoriachama.org/net/MovieFilmOntology#Adult -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Adult">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Audience"/>
        <rdfs:comment xml:lang="en">A movie intended for mature audiences, typically due to explicit content such as violence, sex, or language (often related to an R or NC-17 rating).</rdfs:comment>
        <rdfs:label xml:lang="en">Adult</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Adult"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Audience"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#AdultAnimation -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#AdultAnimation">
        <owl:equivalentClass rdf:nodeID="genid99"/>
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Animation"/>
        <rdfs:subClassOf rdf:nodeID="genid105"/>
        <rdfs:comment xml:lang="en">Animation specifically targeted at an adult or mature audience, often dealing with complex themes, violence, or sexual content.</rdfs:comment>
        <rdfs:label xml:lang="en">AdultAnimation</rdfs:label>
    </owl:Class>
    <owl:Class rdf:nodeID="genid99">
        <owl:intersectionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="http://victoriachama.org/net/MovieFilmOntology#Animation"/>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://victoriachama.org/net/MovieFilmOntology#hasTargetAudience"/>
                <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Adult"/>
            </owl:Restriction>
        </owl:intersectionOf>
    </owl:Class>
    <owl:Class rdf:nodeID="genid105">
        <owl:complementOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://victoriachama.org/net/MovieFilmOntology#hasTargetAudience"/>
                <owl:someValuesFrom rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Children"/>
            </owl:Restriction>
        </owl:complementOf>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#AdultAnimation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2002/07/owl#equivalentClass"/>
        <owl:annotatedTarget rdf:nodeID="genid99"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#AdultAnimation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Animation"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#AdultAnimation"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:nodeID="genid105"/>
        <defeasible:defeasible rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</defeasible:defeasible>
        <www:eTransform rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</www:eTransform>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</www:rank>
    </owl:Axiom>
    


    <!-- http://victoriachama.org/net/MovieFilmOntology#Adventure -->

    <owl:Class rdf:about="http://victoriachama.org/net/MovieFilmOntology#Adventure">
        <rdfs:subClassOf rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Genre"/>
        <rdfs:comment xml:lang="en">A film genre typically characterized by a journey, quest, and exploration of new or exotic locations, often involving risk and excitement.</rdfs:comment>
        <rdfs:label xml:lang="en">Adventure</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Adventure"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://victoriachama.org/net/MovieFilmOntology#Genre"/>
        <www:rank rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</www:rank>
    </owl:Axiom>
    


